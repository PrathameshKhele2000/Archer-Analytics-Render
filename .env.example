# ---- Demo mode (default): runs with generated data, no Archer needed ----
MOCK_MODE=true
MOCK_RECORD_COUNT=50000

# ---- Real Archer connection: set MOCK_MODE=false and fill these in ----
ARCHER_BASE_URL=https://archer.yourcompany.com
ARCHER_INSTANCE=YourInstanceName
ARCHER_USERNAME=svc_analytics
ARCHER_PASSWORD=change-me
ARCHER_USER_DOMAIN=
ARCHER_VERIFY_SSL=true
ARCHER_PAGE_SIZE=1000

# ContentAPI level alias of the application to sync (Application Builder -> Levels -> Alias)
MODULE_ALIAS=Findings

# ETL / caching
SYNC_INTERVAL_MINUTES=15
SYNC_MAX_RETRIES=3
SYNC_RETRY_BASE_MS=2000
CACHE_TTL_SECONDS=900

# JWT auth (change these secrets before any real deployment)
JWT_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=7d

# ---- Single Sign-On (Generic OIDC) ----
# Works with Google, Microsoft Entra/Azure AD, Okta, Keycloak, Auth0, etc.
# Leave OIDC_ISSUER blank to disable SSO (password login still works).
# In your IdP, register a web app with redirect URI = OIDC_REDIRECT_URI below.
#   Google:    OIDC_ISSUER=https://accounts.google.com
#   Entra/AAD: OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
#   Okta:      OIDC_ISSUER=https://<your-org>.okta.com
#   Keycloak:  OIDC_ISSUER=https://<host>/realms/<realm>
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/sso/callback
OIDC_SCOPES=openid email profile
OIDC_DEFAULT_ROLE=viewer
# Where the SSO callback sends the browser back to (the frontend origin)
# FRONTEND_URL=http://localhost:3000
FRONTEND_URL=https://archer-analytics-render.onrender.com
# Deprecated: superseded by JWT auth, no longer read by the app
API_AUTH_TOKEN=
