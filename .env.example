# =====================================================================
#  Archer Analytics — BACKEND configuration (single source of truth)
#
#  This is the COMPLETE list of every setting the backend reads. Nothing
#  else is configured anywhere in code — if it's not here, the app doesn't
#  use it.
#
#  HOW TO USE
#    • Local (Docker):   copy this file to  .env         and fill in values.
#    • Local (native):   copy this file to  backend/.env and fill in values.
#    • Azure (hosting):  DON'T use a file — set each of these as
#                        "Application settings" / environment variables on
#                        your Azure App Service or Container App.
#
#  The real .env is git-ignored. Never commit real secrets. See CONFIGURATION.md
#  for a plain-English explanation of every variable and Azure setup steps.
# =====================================================================


# ---------------------------------------------------------------------
# 1) DATABASE  (PostgreSQL — where the app stores its copy of the data)
# ---------------------------------------------------------------------
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#   • Special characters in the password must be percent-encoded (@ -> %40).
#   • Azure Database for PostgreSQL REQUIRES SSL — append ?sslmode=require.
#
# Local Docker  :  postgresql://archer:archer@db:5432/archer_analytics
# Azure example :  postgresql://myuser:MyP%40ss@my-server.postgres.database.azure.com:5432/archer_analytics?sslmode=require
DATABASE_URL=postgresql://archer:archer@db:5432/archer_analytics

# Max Postgres connections in the pool (optional; default 20).
DB_POOL_MAX=20


# ---------------------------------------------------------------------
# 2) CACHE  (Redis — optional; the app runs fine without it)
# ---------------------------------------------------------------------
# Local Docker :  redis://cache:6379/0
# Azure example:  rediss://<name>.redis.cache.windows.net:6380,password=<key>,ssl=True
REDIS_URL=redis://cache:6379/0
CACHE_TTL_SECONDS=900


# ---------------------------------------------------------------------
# 3) AUTH  (JWT — generate fresh random secrets: `openssl rand -hex 32`)
# ---------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_DIFFERENT_64_char_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d


# ---------------------------------------------------------------------
# 4) APP URL + PORT
# ---------------------------------------------------------------------
# Port the API listens on (Azure sets PORT automatically — leave default locally).
PORT=8000
# Public URL of the frontend (used for SSO redirects). e.g. https://analytics.yourcompany.com
FRONTEND_URL=http://localhost:3000


# ---------------------------------------------------------------------
# 5) SINGLE SIGN-ON  (optional OIDC — leave OIDC_ISSUER blank to keep it OFF)
# ---------------------------------------------------------------------
#   Microsoft Entra / Azure AD: OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
#   Google:                     OIDC_ISSUER=https://accounts.google.com
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/sso/callback
OIDC_SCOPES=openid email profile
OIDC_DEFAULT_ROLE=viewer


# ---------------------------------------------------------------------
# 6) ARCHER SOURCE  (flat MS SQL reporting feed, READ-ONLY)
#    Leave MSSQL_HOST blank to keep the live sync OFF (demo mode).
#    Use a db_datareader account. Point at DEV first, never PROD.
# ---------------------------------------------------------------------
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_DATABASE=ArcherReporting
MSSQL_USER=archer_readonly
MSSQL_PASSWORD=
MSSQL_ENCRYPT=true
MSSQL_TRUST_CERT=false


# ---------------------------------------------------------------------
# 7) SYNC / ETL tuning
# ---------------------------------------------------------------------
# How often the sync pulls changes, in minutes. 1440 = once a day, 15 = every 15 min.
SYNC_INTERVAL_MINUTES=1440
SYNC_MAX_RETRIES=3
SYNC_RETRY_BASE_MS=2000
# Archer application/level alias to sync.
MODULE_ALIAS=Findings
