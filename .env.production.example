# =====================================================================
#  PRODUCTION environment template — copy to .env on the server and fill in.
#  Do NOT commit the real .env. Rotate every secret below; never reuse a
#  value that appeared in development or in chat.
# =====================================================================

# ---- Database (the Postgres that stores your copy of Archer data) ----
# With docker-compose, point at the 'db' service. Use a strong password
# and set POSTGRES_PASSWORD in docker-compose to match.
DATABASE_URL=postgresql://archer:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/archer_analytics

# ---- Cache ----
CACHE_TTL_SECONDS=900

# ---- Auth secrets (generate fresh, e.g. `openssl rand -hex 32`) ----
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_DIFFERENT_64_char_random_string
JWT_REFRESH_TTL=7d

# ---- Single sign-on (point at the same IdP Archer uses) ----
# Leave OIDC_ISSUER empty to keep password login only.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://analytics.yourcompany.com/api/auth/sso/callback
OIDC_SCOPES=openid email profile
OIDC_DEFAULT_ROLE=viewer

# The app's public URL (for SSO redirects and CORS).
FRONTEND_URL=https://analytics.yourcompany.com

# ---- Automatic sync from the flat Archer reporting feed (MS SQL, READ-ONLY) ----
# Use a db_datareader account. Start against DEV, not PROD.
MSSQL_HOST=your-reporting-sql-server
MSSQL_PORT=1433
MSSQL_DATABASE=ArcherReporting
MSSQL_USER=archer_readonly
MSSQL_PASSWORD=CHANGE_ME
MSSQL_ENCRYPT=true
MSSQL_TRUST_CERT=false

# How often the sync pulls changes (minutes). 1440 = once a day.
SYNC_INTERVAL_MINUTES=1440

# =====================================================================
#  FIRST-BOOT CHECKLIST (do these once, on the server):
#    1. Change the default admin password (admin@example.com / ChangeMe123!),
#       or create your own admin and deactivate the default one.
#    2. Confirm DATABASE_URL points at YOUR Postgres and it ran db/install.sql.
#    3. Admin -> Data Sources: point the findings dataset at your real feed table.
#    4. Admin -> Field Mapping: Auto-map, fix leftovers, Save.
#    5. Sync runs automatically; watch Admin -> Sync for the first run.
# =====================================================================
