# Build profile for the Azure deployment ONLY — used by `npm run build:azure`.
#
# Deliberately NOT named ".env.production": Vite loads that filename automatically
# for every production build, which silently pointed the local Docker frontend at
# the Azure backend. Deploy targets must be opt-in.
VITE_API_BASE=https://azure-backend-bhgbb8agh9dgamdn.centralindia-01.azurewebsites.net
