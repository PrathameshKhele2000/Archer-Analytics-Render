# =====================================================================
#  Archer Analytics — FRONTEND configuration
#
#  The frontend has exactly ONE setting: where the backend API lives.
#  It is baked in at BUILD TIME (Vite), so you must REBUILD the frontend
#  after changing it.
#
#  HOW TO USE
#    • Local (Docker / nginx proxy):  leave this UNSET — the app calls /api
#      on the same origin and nginx proxies it to the backend.
#    • Local (vite dev, npm run dev): leave UNSET — vite proxies /api to :8000.
#    • Separate frontend + backend hosts (e.g. Azure Static Web Apps + App
#      Service): set VITE_API_BASE to the backend's absolute URL.
#
#  To use locally, copy this file to  frontend/.env  and set the value.
# =====================================================================

# Absolute base URL of the backend API. Empty = same-origin (proxied).
# Azure example:  https://archer-api.azurewebsites.net
VITE_API_BASE=
